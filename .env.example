# ============================================================
# Gurukul — Environment Configuration
# ============================================================
# Copy this file to `.env` and fill in your actual values.
# Run: cp .env.example .env
#
# NEVER commit the `.env` file to Git. It is already in .gitignore.
# ============================================================

# ─── Server Configuration ───────────────────────────────────
# Port for the Express.js backend API server
PORT=3001

# JWT secret key for signing authentication tokens (change this!)
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your-secure-random-secret-here

# Environment mode: 'development' or 'production'
# In production, cookies are set with Secure flag and app.listen() is skipped (Vercel handles it)
NODE_ENV=development

# ─── Supabase Configuration (Server-Side) ───────────────────
# These are used by the Express.js backend (server/supabase.js)
# Get these from: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── Supabase Configuration (Client-Side / Vite) ────────────
# These are exposed to the React frontend via Vite's import.meta.env
# IMPORTANT: Only VITE_ prefixed variables are accessible in the browser
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Frontend URL (CORS in production) ──────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Google OAuth (Optional) ────────────────────────────────
# Required only if you want Google Sign-In functionality
# Get from: https://console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
